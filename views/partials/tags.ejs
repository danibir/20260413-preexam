
<% for (tag of tags) { %>
    <% if (tag == "søppelpost") { %>
        <br>
    <% } %>
    <input type="checkbox" name="tags[]" value="<%= tag %>" id="<%= tag %>" <% if (pretags.includes(tag)) { %> checked <% } %>>
    <label for="<%= tag %>"><%= tag %> 
    <% if (tagcount) { %>
        (<%= tagcount[tag] %>)
    <% } %>
    </label>
    <br>
<% } %>